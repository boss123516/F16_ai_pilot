<root main_tree_to_execute = "MainTree">


  <BehaviorTree ID="MainTree">
    <Sequence>
       
        <!-- EF 부분 트리-->
        <Sequence>
          <SelectTarget name="SelectTarget" BB="{BB}"/>
          <DirectionVectorUpdate name="DirectionVectorUpdate" BB="{BB}"/>
          <DistanceUpdate name="DistanceUpdateService" BB="{BB}"/>
          <CheckSight name="CheckSight" BB="{BB}"/>          
          <AngleOffUpdate name="AngleOffUpdate" BB="{BB}"/>
          <AspectAngleUpdate name="AspectAngleUpdate" BB="{BB}"/>

          <Fallback>

            <Sequence>
              <DECO_DistanceCheck name="DistanceCheck" UpDown="Greater"  Distance="4000" BB="{BB}"/>
              <Fallback>

                <Sequence>
                  <DECO_AltitudeCheck name="AltitudeCheck" UpDown="Less" InputAlt="1800" BB="{BB}"/>
                  <Task_Climb name="Task_Climb" ClimbAlt="500" BB="{BB}"/>
                </Sequence>

                <Sequence>
                  <DECO_AltitudeCheck name="AltitudeCheck" UpDown="Greater" InputAlt="1800" BB="{BB}"/>
                  <Task_Lead name="Task_Lead" LeadTime="2.5" close_dist="4000" far_dist="9000" min_throttle="0.75" max_throttle="1.0" slew_per_tick="0.05" use_smoothstep="true" BB="{BB}"/>
                </Sequence>

              </Fallback>
            </Sequence>

            <Sequence>
              <DECO_DistanceCheck name="DistanceCheck" UpDown="Greater"  Distance="3000" BB="{BB}"/>
              <DECO_DistanceCheck name="DistanceCheck" UpDown="Less"  Distance="4000" BB="{BB}"/>
              <Fallback>

                <Sequence>
                  <DECO_AltitudeCheck name="AltitudeCheck" UpDown="Less" InputAlt="1800" BB="{BB}"/>
                  <Task_Climb name="Task_Climb" ClimbAlt="500" BB="{BB}"/>
                </Sequence>

                <Sequence>
                  <DECO_AltitudeCheck name="AltitudeCheck" UpDown="Greater" InputAlt="1800" BB="{BB}"/>
                  <Task_Lead name="Task_Lead" LeadTime="1.0" close_dist="3000" far_dist="4000" min_throttle="1.0" max_throttle="1.0" slew_per_tick="0.05" use_smoothstep="true" BB="{BB}"/>
                </Sequence>
              </Fallback>
            </Sequence>

            <Sequence>
              <DECO_DistanceCheck name="DistanceCheck" UpDown="Greater"  Distance="2000" BB="{BB}"/>
              <DECO_DistanceCheck name="DistanceCheck" UpDown="Less"  Distance="3000" BB="{BB}"/>
              <Fallback>
                <Sequence>
                  <DECO_AltitudeCheck name="AltitudeCheck" UpDown="Less" InputAlt="1800" BB="{BB}"/>
                  <Task_Climb name="Task_Climb" ClimbAlt="500" BB="{BB}"/>
                </Sequence>

                <Sequence>
                  <DECO_AltitudeCheck name="AltitudeCheck" UpDown="Greater" InputAlt="1800" BB="{BB}"/>
                  <Task_Lag name="Task_Lag" BB="{BB}" LagDist="100" close_dist="2000" far_dist="3000" min_throttle="0.75" max_throttle="1.0" slew_per_tick="0.05" use_smoothstep="true"/>
                </Sequence>
              </Fallback>
            </Sequence>

            <Sequence>
              <DECO_DistanceCheck name="DistanceCheck" UpDown="Greater"  Distance="1500" BB="{BB}"/>
              <DECO_DistanceCheck name="DistanceCheck" UpDown="Less"  Distance="2000" BB="{BB}"/>
              <Fallback>
                <Sequence>
                  <DECO_AltitudeCheck name="AltitudeCheck" UpDown="Less" InputAlt="1800" BB="{BB}"/>
                  <Task_Climb name="Task_Climb" ClimbAlt="500" BB="{BB}"/>
                </Sequence>

                <Sequence>
                  <DECO_AltitudeCheck name="AltitudeCheck" UpDown="Greater" InputAlt="1800" BB="{BB}"/>
                  <Task_Lag name="Task_Lag" BB="{BB}" LagDist="50" close_dist="1500" far_dist="2000" min_throttle="0.75" max_throttle="1.0" slew_per_tick="0.05" use_smoothstep="true"/>
                </Sequence>
              </Fallback>
            </Sequence>

            <Sequence>
              <DECO_DistanceCheck name="DistanceCheck" UpDown="Less"  Distance="1500" BB="{BB}"/>
              <Fallback>
                <Sequence>
                  <DECO_AltitudeCheck name="AltitudeCheck" UpDown="Less" InputAlt="1800" BB="{BB}"/>
                  <Task_Climb name="Task_Climb" ClimbAlt="500" BB="{BB}"/>
                </Sequence>

                <Sequence>
                  <DECO_AltitudeCheck name="AltitudeCheck" UpDown="Greater" InputAlt="1800" BB="{BB}"/>
                  <Fallback>
                    <SequenceStar>
                      <DECO_LOSTargetCheck name="DECO_LOSTargetCheck" UpDown="Less" InputLOS_Target="2" BB="{BB}"/>
                      <DECO_LOSCheck name="DECO_LOSCheck" UpDown="Greater" InputLOS="3" BB="{BB}"/>
                      <Task_DefensiveBreak name="Task_DefensiveBreak" BreakDist="800" SideOffset="300" KeepAltitude="true" VerticalJink="0" MaxThrottle="true" BB="{BB}"/>
                    </SequenceStar>

                    <SequenceStar>
                    <DECO_LOSTargetCheck name="DECO_LOSTargetCheck" UpDown="Less" InputLOS_Target="2" BB="{BB}"/>
                    <DECO_LOSCheck name="DECO_LOSCheck" UpDown="Less" InputLOS="3" BB="{BB}"/>
                    <DECO_LOSCompare name="LOS_MineGreater" BB="{BB}"/>
                    <Task_DefensiveBreak name="Task_DefensiveBreak" BreakDist="800" SideOffset="300" KeepAltitude="true" VerticalJink="0" MaxThrottle="true" BB="{BB}"/>
                    </SequenceStar>
                    <Task_Pure name="Task_Pure" BB="{BB}"/>
                    
                  </Fallback>
                </Sequence>
              </Fallback>
            </Sequence>
          </Fallback>
        </Sequence>
    </Sequence>
  </BehaviorTree>
</root>